# Agentiful Environment Variables

# ========================================
# Database (PostgreSQL 18)
# ========================================
DATABASE_URL=postgresql://user:password@localhost:5432/agentiful
DATABASE_POOL_SIZE=10

# ========================================
# Redis (Sessions & Cache)
# ========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ========================================
# API Server
# ========================================
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# ========================================
# Web Server
# ========================================
WEB_PORT=3000
WEB_URL=http://localhost:3000

# ========================================
# Authentication
# ========================================
BETTER_AUTH_SECRET=your-secret-key-change-this
BETTER_AUTH_URL=http://localhost:3001
ACCESS_TOKEN_TTL=900m
REFRESH_TOKEN_TTL=7d

# ========================================
# Email (Resend)
# ========================================
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@agentiful.com
RESEND_FROM_NAME=Agentiful

# ========================================
# SSO Providers
# ========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ========================================
# Observability
# ========================================
OTEL_SERVICE_NAME=agentiful-api
OTEL_EXPORTER_OTLP_ENDPOINT=
TRACE_SAMPLING_RATE=1.0

# ========================================
# Security
# ========================================
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_DURATION=30m

# ========================================
# Features
# ========================================
ENABLE_SSO=true
ENABLE_MFA=true
ENABLE_USER_APPROVAL=false
DEFAULT_LANGUAGE=en

# ========================================
# RBAC Authorization (S1-2)
# ========================================
# Enable ROOT ADMIN role (default: false)
ENABLE_ROOT_ADMIN=false
# Permission cache TTL in seconds (default: 5)
PERMISSION_CACHE_TTL=5
# Permission check timeout in milliseconds (default: 50)
PERMISSION_CHECK_TIMEOUT=50
# Max direct grant expiration in days (default: 90)
MAX_DIRECT_GRANT_EXPIRES_DAYS=90
# Break-glass session duration in minutes (default: 60)
BREAKGLASS_SESSION_DURATION=60
