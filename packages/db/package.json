{
  "name": "@agentifui/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/client.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema/index.ts",
    "./schema/*": "./src/schema/*.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "seed": "tsx src/seed/index.ts",
    "seed:rbac": "tsx src/seed/rbac.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentifui/shared": "workspace:*",
    "drizzle-orm": "^0.36.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.29.1",
    "postgres": "^3.4.5",
    "tsx": "^4.19.2",
    "typescript": "^5.8.0"
  }
}
